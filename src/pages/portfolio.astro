---
import Layout from '../layouts/Layout.astro';
---
<Layout title="VirtualStruct &mdash; Portfolio" ogTitle="VirtualStruct &mdash; Portfolio" showBack={true}>

  <div class="bento-page">
    <div class="bento-grid">

      <!-- Header row -->
      <div class="bcard bcard-full bcard-nav">
        <span class="bento-page-title">Portfolio</span>
      </div>

      <!-- About (2 cols) + Quick info (1 col) -->
      <div class="bcard bcard-2">
        <span class="bcard-label">About</span>
        <p>I am a Backend Developer with five years building REST APIs, real-time platforms, multi-tenant architectures, and CI/CD pipelines.</p>
        <p>Stack: NestJS, Laravel, Node.js, Go, SQL and NoSQL, Docker, AWS, GCP.</p>
      </div>

      <div class="bcard">
        <span class="bcard-label">Location</span>
        <p>Algeria &middot; UTC+1<br>Open to remote</p>
        <br>
        <span class="bcard-label">Links</span>
        <a href="https://github.com/hihebark" class="bcard-link">GitHub</a><br>
        <a href="https://www.linkedin.com/in/nezliamara/" class="bcard-link">LinkedIn</a><br>
        <a href="mailto:n.amara@protonmail.ch" class="bcard-link">n.amara@protonmail.ch</a>
      </div>

      <!-- Skills full-width -->
      <div class="bcard bcard-full">
        <span class="bcard-label">Skills</span>
        <div class="bcard-skills">
          <div class="bcard-skill-group">
            <h4>Languages</h4>
            <ul>
              <li>PHP (Laravel)</li>
              <li>Node.js / TypeScript</li>
              <li>Python</li>
              <li>Go</li>
            </ul>
          </div>
          <div class="bcard-skill-group">
            <h4>Databases</h4>
            <ul>
              <li>MySQL</li>
              <li>PostgreSQL</li>
              <li>MongoDB</li>
              <li>Redis</li>
            </ul>
          </div>
          <div class="bcard-skill-group">
            <h4>DevOps</h4>
            <ul>
              <li>Docker</li>
              <li>Linux</li>
              <li>AWS / GCP</li>
              <li>CI/CD</li>
            </ul>
          </div>
          <div class="bcard-skill-group">
            <h4>Other</h4>
            <ul>
              <li>RESTful APIs</li>
              <li>WebSockets</li>
              <li>Git</li>
              <li>Agile</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Experience: all entries in one card -->
      <div class="bcard bcard-full">
        <span class="bcard-section-title">Experience</span>

        <div class="exp-entry">
          <span class="bcard-label">CQR &middot; Jun 2026 — Present</span>
          <h3>NestJS Backend Developer</h3>
          <ul>
            <li>Architected a multi-tenant REST API with organization-scoped access control and role-based permissions.</li>
          </ul>
          <div class="stack">
            <span>NestJS</span><span>TypeScript</span><span>Keycloak</span><span>Docker</span>
          </div>
        </div>

        <div class="exp-entry">
          <span class="bcard-label">Freelancing &middot; Jul 2023 — Jun 2026</span>
          <h3>Full-stack Developer</h3>
          <ul>
            <li>Designed and implemented <a href="https://zirak.info" class="bcard-link">Zirak</a>, a car-sharing app using WebSocket for real-time communication.</li>
            <li>Built server-side logic in Node.js and Laravel; managed SQL databases.</li>
            <li>Configured and deployed several applications on GCP and AWS.</li>
          </ul>
          <div class="stack">
            <span>Node.js</span><span>Laravel</span><span>SQL</span><span>WebSocket</span><span>GCP</span><span>AWS</span><span>GNU/Linux</span>
          </div>
        </div>

        <div class="exp-entry">
          <span class="bcard-label">Developatic &middot; May 2020 — Jul 2023</span>
          <h3>Mid-Senior Node.js &amp; Laravel Backend Developer</h3>
          <ul>
            <li>Built multiple projects from scratch: <a href="https://docminute.app" class="bcard-link">Docminute</a>, <a href="https://heyu.paris" class="bcard-link">HeyU</a>, Gratify, and Zer.</li>
            <li>Refactored and migrated legacy code, reducing system downtime by 50% across projects like <a href="https://sherpas.com" class="bcard-link">Sherpas</a>.</li>
            <li>Built and maintained a CI/CD pipeline, cutting deployment time on each project.</li>
          </ul>
          <div class="stack">
            <span>Node.js</span><span>Laravel</span><span>SQL/NoSQL</span><span>Docker</span><span>AWS</span><span>GCP</span><span>Stripe</span>
          </div>
        </div>

        <div class="exp-entry" style="margin-bottom:0">
          <span class="bcard-label">PiLabs &middot; Jan 2019 — Mar 2020</span>
          <h3>Junior Node.js Backend Developer</h3>
          <ul>
            <li>Designed and developed a POS for automotive spare parts: transactions, inventory, and reporting.</li>
            <li>Wrote server-side Node.js code; improved response times and reduced failure rates.</li>
          </ul>
          <div class="stack">
            <span>Node.js</span><span>Python</span><span>NoSQL</span><span>AWS IAM</span><span>AWS S3</span>
          </div>
        </div>
      </div>

      <!-- Education + Languages -->
      <div class="bcard bcard-2">
        <span class="bcard-section-title">Education</span>
        <div class="exp-entry">
          <span class="bcard-label">University Abdelhamid Mehri</span>
          <h3>Master &middot; Networking &amp; Distributed Systems</h3>
        </div>
        <div class="exp-entry" style="margin-bottom:0">
          <span class="bcard-label">University Abdelhamid Mehri</span>
          <h3>Licence &middot; Computer Science</h3>
        </div>
      </div>

      <div class="bcard">
        <span class="bcard-section-title">Languages</span>
        <ul>
          <li>Arabic &middot; Native</li>
          <li>French &middot; Professional</li>
          <li>English &middot; Professional</li>
        </ul>
      </div>

    </div>
  </div>

</Layout>
