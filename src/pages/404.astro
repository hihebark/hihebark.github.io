---
import Layout from '../layouts/Layout.astro';
---
<Layout title="VirtualStruct &mdash; 404" script={false} centered={true}>
  <Fragment slot="head">
    <style>
      .err-code {
        font-size: clamp(5rem, 18vw, 9rem);
        font-weight: 700;
        color: var(--green);
        letter-spacing: 12px;
        line-height: 1;
        animation: glitch 4s ease infinite;
      }
      .err-output {
        margin-top: 20px;
        font-size: 12px;
        color: var(--muted);
        line-height: 2;
      }
      .err-output .tline { color: var(--text); }
      .err-output .err   { color: #ff4d4d; }
      .err-hint {
        margin-top: 20px;
        font-size: 12px;
        color: var(--muted);
      }
      .err-hint a { color: var(--green); text-decoration: none; }
      .err-hint a:hover { color: #000; background: var(--green); }
      .blink {
        color: var(--green);
        animation: blink 1s infinite;
      }
      @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
    </style>
  </Fragment>

  <p class="err-code">404</p>

  <div class="err-output">
    <p class="tline">$ cd /requested-path</p>
    <p class="err">bash: cd: /requested-path: No such file or directory</p>
  </div>

  <p class="err-hint">
    $ <a href="/">cd ~/Index</a> <span class="blink">&#9608;</span>
  </p>
</Layout>
