---
import Layout from '../layouts/Layout.astro';
---
<Layout title="VirtualStruct" ogTitle="VirtualStruct">
  <div class="hero-bento reveal">
    <div class="hero-left">
      <p class="hero-name">Amara Nezli</p>
      <p class="hero-title">Backend Developer &middot; Algeria</p>

      <p class="hero-bio">Building production systems with NestJS, Laravel, and Go. 5+ years turning specs into shipped software.</p>

      <p class="social">
        <a href="https://github.com/hihebark">Github</a> &middot;
        <a href="https://twitter.com/virtualstruct">X</a> &middot;
        <a href="https://www.linkedin.com/in/nezliamara/">LinkedIn</a> &middot;
        <a href="https://www.instagram.com/virtualstruct/">Instagram</a>
      </p>

      <div class="status-line">
        <span class="status-dot"></span>
        <span>NestJS / Laravel &mdash; DZ &middot; <span id="status-clock">--:--:--</span></span>
      </div>
    </div>

    <div class="hero-right">
      <div class="terminal">
        <div class="terminal-bar">
          <i></i><i></i><i></i>
          <span>bash &mdash; 80&times;24</span>
        </div>
        <div class="terminal-body"></div>
      </div>
    </div>
  </div>
</Layout>
